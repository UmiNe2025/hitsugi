+/* 選択中の札は太枠と菱形印で示し、色だけに頼らない。カードのクリックは再選択であり実行ではない。 */
+.combatant.is-selected-target .battle-art-frame {
+  outline: 3px solid var(--sel);
+  outline-offset: 3px;
