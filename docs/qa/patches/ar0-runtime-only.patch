+  flex: 0 1 auto;
+  min-width: 0;
+  max-width: 11em;
+  overflow: hidden;
+  text-overflow: ellipsis;
+}
+.battle-top-rail .loot-slot {
+  position: relative;
+  inset: auto;
+  flex: 0 0 auto;
+  transform: none;
+  margin-right: 2px;
+}
+.battle-top-rail .loot-slot .slot-reel { flex-shrink: 0; }
