diff --git a/scripts/validate_visual_recovery_manifest.mjs b/scripts/validate_visual_recovery_manifest.mjs
new file mode 100644
index 0000000..a1d8a86
--- /dev/null
+++ b/scripts/validate_visual_recovery_manifest.mjs
@@ -0,0 +1,49 @@
+import fs from 'node:fs'
+import path from 'node:path'
+import { fileURLToPath } from 'node:url'
+
+const root = path.resolve(path.dirname(fileURLToPath(import.meta.url)), '..')
+const manifestPath = path.join(root, 'assets_src', 'visual_recovery', 'asset-manifest.json')
+const entries = JSON.parse(fs.readFileSync(manifestPath, 'utf8'))
+const required = [
+  'assetId', 'screen', 'role', 'family', 'state', 'requiredStates', 'dimensions', 'alpha',
+  'crop', 'collision', 'source', 'generator', 'modelLicenseChain', 'rightsStatus',
+  'promptVersion', 'reviewStatus', 'reviewer', 'rejectReason', 'sha256',
+]
+const screens = new Set(['home', 'village', 'dungeon', 'battle', 'pact', 'forge', 'storehouse'])
+const reviewStatuses = new Set(['planned', 'generated', 'needs-review', 'accepted', 'rejected'])
+const rightsStatuses = new Set(['planned', 'unverified', 'cleared', 'rejected'])
+const ids = new Set()
+const errors = []
+
+for (const [index, entry] of entries.entries()) {
+  const at = `entry[${index}]`
+  for (const key of required) if (!(key in entry)) errors.push(`${at}: missing ${key}`)
+  if (!/^[a-z0-9_]+$/.test(entry.assetId ?? '')) errors.push(`${at}: invalid assetId`)
+  if (ids.has(entry.assetId)) errors.push(`${at}: duplicate assetId ${entry.assetId}`)
+  ids.add(entry.assetId)
+  if (!screens.has(entry.screen)) errors.push(`${at}: invalid screen ${entry.screen}`)
+  if (!reviewStatuses.has(entry.reviewStatus)) errors.push(`${at}: invalid reviewStatus`)
+  if (!rightsStatuses.has(entry.rightsStatus)) errors.push(`${at}: invalid rightsStatus`)
+  if (!Number.isInteger(entry.dimensions?.width) || entry.dimensions.width < 1 || !Number.isInteger(entry.dimensions?.height) || entry.dimensions.height < 1) errors.push(`${at}: invalid dimensions`)
+  for (const crop of ['pc', 'tablet', 'mobile390', 'mobile360']) if (!entry.crop?.[crop]) errors.push(`${at}: missing crop.${crop}`)
+  if (!Array.isArray(entry.requiredStates) || entry.requiredStates.length === 0) errors.push(`${at}: requiredStates must be non-empty`)
+  if (entry.sha256 !== null && !/^[a-f0-9]{64}$/i.test(entry.sha256)) errors.push(`${at}: invalid sha256`)
+  if (entry.reviewStatus === 'accepted') {
+    if (entry.rightsStatus !== 'cleared') errors.push(`${at}: accepted asset rights are not cleared`)
+    if (!entry.source || !entry.generator || !entry.modelLicenseChain || !entry.reviewer || !entry.sha256) errors.push(`${at}: accepted asset provenance is incomplete`)
+  }
+  if (entry.reviewStatus === 'rejected' && !entry.rejectReason) errors.push(`${at}: rejected asset needs rejectReason`)
+}
+
+const requiredVillageIds = [
+  'village_facade_great_lantern', 'village_facade_forge_storehouse', 'village_facade_star_shrine',
+  'village_facade_tofu_shop', 'village_facade_departure_gate',
+]
+for (const id of requiredVillageIds) if (!ids.has(id)) errors.push(`missing AR1 village ID ${id}`)
+
+if (errors.length) {
+  console.error(errors.join('\n'))
+  process.exit(1)
+}
+console.log(`visual manifest OK: ${entries.length} entries, ${ids.size} unique IDs`)
