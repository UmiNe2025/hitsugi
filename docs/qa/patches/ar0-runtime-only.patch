+}
+.combatant.is-selected-target::after {
+  content: '◆ 選択';
+  position: absolute;
+  z-index: 16;
+  top: -17px;
+  left: 50%;
+  transform: translateX(-50%);
+  padding: 1px 6px;
+  border-radius: 8px;
+  background: var(--sel);
+  color: var(--night-deep);
+  font-size: 9.5px;
+  font-weight: 800;
+  white-space: nowrap;
